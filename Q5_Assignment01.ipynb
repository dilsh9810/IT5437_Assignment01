#Compute a normalized 5 * 5 Gaussian kernel

import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D
import cv2

def create_gaussian_kernel(size, sigma):
    #Create a coordinate grid centered at zero
    ax = np.linspace(-(size // 2), size // 2, size)
    x, y = np.meshgrid(ax, ax)

    #Calculate the Gaussian function
    kernel = np.exp(-(x**2 + y **2) / (2 * sigma**2))

    #Normalize the kernel so the sum is 1
    return kernel / np.sum(kernel)

# a). 5 * 5 Kernel for sigma = 2
kernel_5x5 = create_gaussian_kernel(5, 2)
print("5x5 Normalized Gaussian Kernel:\n", kernel_5x5)
